rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==================== HELPER FUNCTIONS ====================

    /// Check if the current user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    /// Check if the current user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /// Check if the current user is a participant in the conversation
    function isParticipant(conversationId) {
      return isAuthenticated() &&
        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    /// Validate that the data does not contain plaintext messages
    function hasNoPlaintext() {
      return !request.resource.data.keys().hasAny(['plaintext', 'plaintextCache', 'content', 'body']);
    }

    /// Validate public key format (64-char hex string)
    function isValidPublicKey(key) {
      return key is string && key.size() == 64 && key.matches('^[0-9a-fA-F]+$');
    }

    // ==================== USERS COLLECTION ====================

    match /users/{userId} {
      // Allow read if authenticated - users can discover other users' public keys
      allow read: if isAuthenticated();

      // Allow write only to own document
      allow write: if isOwner(userId);

      // Validate user document structure on create
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['publicKey'])
        && isValidPublicKey(request.resource.data.publicKey)
        && (!request.resource.data.keys().hasAny(['fcmToken']) ||
            request.resource.data.fcmToken is string || request.resource.data.fcmToken == null)
        && (!request.resource.data.keys().hasAny(['encryptedContacts']) ||
            request.resource.data.encryptedContacts is string);

      // Validate updates - prevent overwriting critical fields
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['createdAt']));
    }

    // ==================== CONVERSATIONS COLLECTION ====================

    match /conversations/{conversationId} {
      // Allow read if user is a participant
      allow read: if isAuthenticated()
        && request.auth.uid in resource.data.participants;

      // Allow create if user is a participant in the new conversation
      allow create: if isAuthenticated()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2
        && request.resource.data.keys().hasAll(['participants', 'lastMessageAt']);

      // Allow update if user is a participant (for lastMessageAt updates)
      allow update: if isParticipant(conversationId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessageAt']);

      // ==================== MESSAGES SUBCOLLECTION ====================

      match /messages/{messageId} {
        // Allow read if user is a participant in the parent conversation
        allow read: if isAuthenticated()
          && isParticipant(conversationId);

        // Allow create if user is a participant and sending as self
        allow create: if isAuthenticated()
          && isParticipant(conversationId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.keys().hasAll(['senderId', 'ciphertext', 'timestamp', 'status', 'messageType'])
          && request.resource.data.ciphertext is string
          && request.resource.data.ciphertext.size() > 0
          // SECURITY: Ensure no plaintext is stored
          && hasNoPlaintext();

        // Allow update for status changes (delivered/read)
        allow update: if isAuthenticated()
          && isParticipant(conversationId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status in ['sent', 'delivered', 'read'];

        // No delete - messages are permanent
        allow delete: if false;
      }
    }

    // ==================== DEFAULT DENY ====================

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
